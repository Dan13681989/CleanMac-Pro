#!/bin/bash
set -euo pipefail

# Dry-run flag
DRY_RUN=false
if [[ "${1:-}" == "--dry-run" ]]; then
    DRY_RUN=true
    shift
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}=== CleanMac Pro Cleaner ===${NC}"
if [[ "$DRY_RUN" == true ]]; then
    echo -e "${YELLOW}DRY RUN MODE – no files will be deleted${NC}"
fi

# Helper function
clean_item() {
    local path="$1"
    local description="${2:-$path}"
    if [[ -e "$path" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo -e "[DRY RUN] Would delete: $description"
        else
            rm -rf "$path" && echo -e "${GREEN}Deleted:${NC} $description"
        fi
    else
        echo -e "[SKIP] $description not found"
    fi
}

# ============================================
# Real cleaning items (copied from original)
# ============================================
# The original script deleted these:
clean_item "$HOME/Library/Caches" "User caches"
clean_item "$HOME/Library/Logs" "User logs"
clean_item "$HOME/.Trash" "Trash"
clean_item "/Library/Caches" "System caches (requires sudo)" 2>/dev/null || true
clean_item "$HOME/Library/Application Support/Code/Cache" "VS Code cache"
clean_item "$HOME/Library/Containers/com.apple.Safari/Data/Library/Caches" "Safari caches"
clean_item "$HOME/Library/Containers/com.apple.mail/Data/Library/Caches" "Mail caches"
clean_item "$HOME/Library/Developer/Xcode/DerivedData" "Xcode derived data"
clean_item "$HOME/Library/Developer/Xcode/Archives" "Xcode archives"

echo -e "${GREEN}Cleanup finished.${NC}"
