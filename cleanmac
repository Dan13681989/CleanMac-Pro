#!/bin/bash
set -euo pipefail

# ============================================
# Configuration
# ============================================
VERSION="3.2.0"
LOG_DIR="$HOME/.cleanmac"
LOG_FILE="$LOG_DIR/cleanmac.log"
CONFIG_FILE="$LOG_DIR/config"
mkdir -p "$LOG_DIR"

# Defaults
QUIET=false
JSON_OUT=false
LOG_LEVEL="info"

# Load configuration (simple key=value)
if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
fi

# Prefix handling
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
    PREFIX="$HOMEBREW_PREFIX/opt/cleanmac-pro"
elif [[ -f "$(dirname "$0")/cleanmac-clean-now" ]]; then
    PREFIX="$(dirname "$0")"
else
    PREFIX="@PREFIX@"
fi

# ============================================
# Helper functions
# ============================================
log() {
    local level="$1"
    shift
    [[ "$LOG_LEVEL" == "debug" && "$level" != "ERROR" && "$level" != "WARN" ]] && return 0
    [[ "$level" == "ERROR" ]] && local prefix="[ERROR]"
    [[ "$level" == "WARN" ]] && local prefix="[WARN]"
    [[ "$level" == "INFO" ]] && local prefix="[INFO]"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $prefix $*" >> "$LOG_FILE"
    if [[ "$QUIET" == false && "$JSON_OUT" == false ]]; then
        >&2 echo "$*"
    fi
}

error() {
    log "ERROR" "$*"
    if [[ "$JSON_OUT" == true ]]; then
        echo "{\"error\": \"$*\"}"
    else
        echo "ERROR: $*" >&2
    fi
    exit 1
}

warn() {
    log "WARN" "$*"
    if [[ "$JSON_OUT" == false && "$QUIET" == false ]]; then
        echo "Warning: $*" >&2
    fi
}

info() {
    log "INFO" "$*"
    if [[ "$JSON_OUT" == false && "$QUIET" == false ]]; then
        echo "$*"
    fi
}

json_output() {
    if [[ "$JSON_OUT" == true ]]; then
        echo "$1"
    fi
}

rotate_logs() {
    if [[ -f "$LOG_FILE" && $(stat -f%z "$LOG_FILE") -gt 5242880 ]]; then
        mv "$LOG_FILE" "$LOG_FILE.old"
        info "Log rotated (old size >5MB)"
    fi
}

check_dependency() {
    local cmd="$1"
    local pkg="${2:-$1}"
    local msg="$3"
    if ! command -v "$cmd" &> /dev/null; then
        warn "$msg. Install with: brew install $pkg"
        return 1
    fi
    return 0
}

check_sudo() {
    if ! sudo -n true 2>/dev/null; then
        warn "Some commands require sudo. You may be prompted for your password."
    fi
}

# ============================================
# Parse global options
# ============================================
while [[ $# -gt 0 ]]; do
    case "$1" in
        --quiet) QUIET=true; shift ;;
        --json) JSON_OUT=true; shift ;;
        --log-level) LOG_LEVEL="$2"; shift 2 ;;
        --help|-h) COMMAND="help"; shift ;;
        --version|-v) COMMAND="version"; shift ;;
        *) break ;;
    esac
done

# ============================================
# Command handlers
# ============================================
cmd_clean() {
    local force=false
    for arg in "$@"; do
        if [[ "$arg" == "--force" ]]; then
            force=true
            shift
        fi
    done
    check_sudo
    if [[ "$JSON_OUT" == true ]]; then
        local output
        output=$(sudo "$PREFIX/cleanmac-clean-now" --dry-run 2>&1)
        output=$(echo "$output" | sed 's/"/\\"/g' | awk '{print "\""$0"\\n"}' | tr -d '\n' | sed 's/\\n$//')
        echo "{\"dry_run\": true, \"actions\": \"$output\"}"
    else
        if [[ "$force" == true ]]; then
            exec sudo "$PREFIX/cleanmac-clean-now" --force "$@"
        else
            exec sudo "$PREFIX/cleanmac-clean-now" "$@"
        fi
    fi
}

cmd_dashboard() {
    exec "$PREFIX/cleanmac-dashboard" "$@"
}

cmd_analyze() {
    check_dependency "ncdu" "ncdu" "ncdu is required for disk analysis" || exit 1
    exec "$PREFIX/cleanmac-analyze" "$@"
}

cmd_large_files() {
    exec "$PREFIX/cleanmac-large-files" "$@"
}

cmd_docker() {
    local size
    for arg in "$@"; do
        if [[ "$arg" =~ ^-s[[:space:]]*([0-9]+)$ ]]; then
            size="${BASH_REMATCH[1]}"
            if ! [[ "$size" =~ ^[0-9]+$ ]]; then
                error "--size must be a positive integer (GB)"
            fi
        fi
    done
    exec "$PREFIX/cleanmac-docker-clean" "$@"
}

cmd_security() {
    exec "$PREFIX/cleanmac-security-scan" "$@"
}

cmd_network() {
    local sub="${1:-help}"
    shift || true
    case "$sub" in
        status)
            if [[ "$JSON_OUT" == true ]]; then
                PUBLIC_IP=$(curl -s --max-time 3 ipinfo.io/ip 2>/dev/null || curl -s --max-time 3 ifconfig.me 2>/dev/null || curl -s --max-time 3 icanhazip.com 2>/dev/null || echo "Unavailable")
                LOCAL_IP=$(ifconfig | grep -E "inet ([0-9]{1,3}\.){3}[0-9]{1,3}" | grep -v 127.0.0.1 | head -1 | awk '{print $2}')
                [ -z "$LOCAL_IP" ] && LOCAL_IP="Not connected"
                DNS=$(scutil --dns | grep 'nameserver\[[0-9]*\]' | awk '{print $3}' | sort -u | tr '\n' ' ')
                echo "{\"public_ip\": \"$PUBLIC_IP\", \"local_ip\": \"$LOCAL_IP\", \"dns_servers\": [$(echo "$DNS" | sed 's/ /", "/g' | sed 's/^/"/;s/ $//')]}"
            else
                echo "=== Network Status ==="
                PUBLIC_IP=$(curl -s --max-time 3 ipinfo.io/ip 2>/dev/null || curl -s --max-time 3 ifconfig.me 2>/dev/null || curl -s --max-time 3 icanhazip.com 2>/dev/null || echo "Unavailable")
                echo "Public IP: $PUBLIC_IP"
                LOCAL_IP=$(ifconfig | grep -E "inet ([0-9]{1,3}\.){3}[0-9]{1,3}" | grep -v 127.0.0.1 | head -1 | awk '{print $2}')
                [ -z "$LOCAL_IP" ] && LOCAL_IP="Not connected"
                echo "Local IP: $LOCAL_IP"
                DNS=$(scutil --dns | grep 'nameserver\[[0-9]*\]' | awk '{print $3}' | sort -u | tr '\n' ' ')
                echo "DNS Servers: $DNS"
            fi
            ;;
        flush-dns)
            check_sudo
            echo "Flushing DNS cache..."
            sudo dscacheutil -flushcache
            sudo killall -HUP mDNSResponder
            echo "DNS cache flushed."
            ;;
        optimize)
            check_sudo
            if [[ -x "$PREFIX/scripts/network_optimizer.sh" ]]; then
                sudo "$PREFIX/scripts/network_optimizer.sh"
            else
                echo "Optimizer script not found. Applying safe defaults:"
                sudo dscacheutil -flushcache
                sudo killall -HUP mDNSResponder
                sudo sysctl -w net.inet.tcp.win_scale_factor=8
                sudo sysctl -w net.inet.tcp.autorcvbufmax=33554432
                sudo sysctl -w net.inet.tcp.autosndbufmax=33554432
            fi
            ;;
        reset)
            check_sudo
            echo "Resetting TCP settings to macOS defaults..."
            sudo sysctl -w net.inet.tcp.win_scale_factor=3
            sudo sysctl -w net.inet.tcp.autorcvbufmax=4194304
            sudo sysctl -w net.inet.tcp.autosndbufmax=4194304
            echo "TCP settings reset. DNS cache unchanged."
            ;;
        monitor)
            if [[ -x "$PREFIX/scripts/network_monitor.sh" ]]; then
                exec "$PREFIX/scripts/network_monitor.sh"
            else
                error "Network monitor not available. Reinstall with: brew reinstall cleanmac-pro"
            fi
            ;;
        ping)
            local target="${1:-8.8.8.8}"
            echo "Pinging $target..."
            ping -c 5 "$target"
            ;;
        help|--help|-h)
            cat << NETHELP
Network Commands:
  cleanmac network status      Show current network status (IP, DNS)
  cleanmac network flush-dns   Flush DNS cache
  cleanmac network optimize    Apply DNS + TCP optimizations
  cleanmac network reset       Reset TCP to macOS defaults
  cleanmac network monitor     Launch network monitor (if available)
  cleanmac network ping <host> Ping a host (default: 8.8.8.8)
NETHELP
            ;;
        *)
            error "Unknown network subcommand: $sub\nRun 'cleanmac network help'"
            ;;
    esac
}

cmd_upgrade() {
    if [[ -d "$(dirname "$0")/.git" ]]; then
        echo "Upgrading from git repository..."
        git -C "$(dirname "$0")" pull --rebase
        make -C "$(dirname "$0")" install 2>/dev/null || {
            echo "Manual reinstall required: cd $(dirname "$0") && ./install.sh"
        }
    else
        warn "Homebrew installation detected. Run: brew upgrade cleanmac-pro"
    fi
}

cmd_uninstall() {
    echo "Removing CleanMac Pro..."
    read -p "Also remove logs and config in $LOG_DIR? (y/N): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        rm -rf "$LOG_DIR"
    fi
    read -p "Untap Homebrew tap? (y/N): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        brew untap dan13681989/cleanmac 2>/dev/null || true
    fi
    exec "$PREFIX/uninstall.sh"
}

# ---- New commands ----
cmd_startup() {
    local action="${1:-list}"
    shift || true
    case "$action" in
        list)
            osascript -e 'tell application "System Events" to get the name of every login item' 2>/dev/null || echo "No login items found"
            ;;
        add)
            if [[ -z "$1" ]]; then
                error "Usage: cleanmac startup add <path/to/app.app>"
            fi
            osascript -e "tell application \"System Events\" to make login item at end with properties {path:\"$1\", hidden:false}" 2>/dev/null
            echo "Added: $1"
            ;;
        remove)
            if [[ -z "$1" ]]; then
                error "Usage: cleanmac startup remove <app name>"
            fi
            osascript -e "tell application \"System Events\" to delete login item \"$1\"" 2>/dev/null
            echo "Removed: $1"
            ;;
        *)
            error "Unknown startup action: $action\nUsage: cleanmac startup [list|add|remove]"
            ;;
    esac
}

cmd_defaults() {
    local action="${1:-help}"
    shift || true
    case "$action" in
        show-hidden-files)
            local status=$(defaults read com.apple.finder AppleShowAllFiles 2>/dev/null || echo "0")
            if [[ "$status" == "1" ]]; then
                echo "Hidden files are shown"
            else
                echo "Hidden files are hidden"
            fi
            ;;
        toggle-hidden-files)
            local status=$(defaults read com.apple.finder AppleShowAllFiles 2>/dev/null || echo "0")
            if [[ "$status" == "1" ]]; then
                defaults write com.apple.finder AppleShowAllFiles -bool false
                echo "Hidden files hidden"
            else
                defaults write com.apple.finder AppleShowAllFiles -bool true
                echo "Hidden files shown"
            fi
            killall Finder 2>/dev/null || true
            ;;
        show-path-in-finder)
            defaults write com.apple.finder ShowPathbar -bool true
            killall Finder 2>/dev/null || true
            echo "Path bar shown in Finder"
            ;;
        *)
            cat << DEFAULTSHELP
Defaults Management:
  cleanmac defaults show-hidden-files      Show current hidden files status
  cleanmac defaults toggle-hidden-files    Toggle showing hidden files
  cleanmac defaults show-path-in-finder    Show path bar in Finder windows
DEFAULTSHELP
            ;;
    esac
}

# ---- Existing commands (system-info, battery, apps, schedule) ----
cmd_system_info() {
    echo "=== System Information ==="
    echo "Hostname: $(scutil --get ComputerName 2>/dev/null || echo 'Unknown')"
    echo "macOS: $(sw_vers -productVersion 2>/dev/null || echo 'Unknown')"
    echo "Kernel: $(uname -r 2>/dev/null || echo 'Unknown')"
    echo "Uptime: $(uptime | awk -F'up ' '{print $2}' | awk -F',' '{print $1}')"
    echo "CPU: $(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo 'Unknown')"
    echo "Cores: $(sysctl -n hw.ncpu 2>/dev/null || echo 'Unknown')"
    echo "Memory: $(($(sysctl -n hw.memsize 2>/dev/null || echo 0) / 1073741824)) GB"
    echo "Disk: $(df -h / | awk 'NR==2 {print $4 " free of " $2}')"
}

cmd_battery() {
    local batt_info=$(system_profiler SPPowerDataType 2>/dev/null | grep -E "Cycle Count|Health|Condition")
    if [[ -n "$batt_info" ]]; then
        echo "=== Battery Information ==="
        echo "$batt_info"
    else
        echo "No battery detected (or not a laptop)."
    fi
}

cmd_apps() {
    echo "=== Large Applications ==="
    echo "Scanning /Applications and ~/Applications..."
    echo "Showing apps > 1GB:"
    find /Applications ~/Applications -maxdepth 3 -name "*.app" -type d -exec du -sm {} \; 2>/dev/null | sort -nr | awk '$1 > 1024 {printf "%.2f GB\t%s\n", $1/1024, $2}' | head -20
    echo ""
    echo "To remove an app, drag it to Trash or use: brew uninstall <app>"
}

cmd_schedule() {
    local action="${1:-help}"
    shift || true
    case "$action" in
        add)
            local freq="${1:-weekly}"
            local script_path="$PREFIX/cleanmac-clean-now"
            local log_path="$LOG_DIR/scheduled.log"
            local cron_cmd="$script_path >> $log_path 2>&1"
            case "$freq" in
                daily)   local schedule="0 2 * * *" ;;
                weekly)  local schedule="0 2 * * 0" ;;
                monthly) local schedule="0 2 1 * *" ;;
                *) error "Frequency must be daily, weekly, or monthly" ;;
            esac
            echo "Adding schedule: $freq (cron: $schedule)"
            (crontab -l 2>/dev/null; echo "$schedule $cron_cmd") | crontab -
            echo "Schedule added. Logs: $log_path"
            ;;
        remove)
            echo "Removing all CleanMac Pro scheduled jobs..."
            crontab -l 2>/dev/null | grep -v "cleanmac-clean-now" | crontab -
            echo "Scheduled jobs removed."
            ;;
        status)
            echo "Current scheduled jobs:"
            crontab -l 2>/dev/null | grep "cleanmac" || echo "No CleanMac jobs found."
            ;;
        help|--help|-h)
            cat << SCHEDHELP
Schedule Management:
  cleanmac schedule add daily|weekly|monthly   Add a recurring cleaning job
  cleanmac schedule remove                      Remove all scheduled jobs
  cleanmac schedule status                      Show current scheduled jobs
SCHEDHELP
            ;;
        *)
            error "Unknown schedule action: $action\nRun 'cleanmac schedule help'"
            ;;
    esac
}

# ============================================
# Main CLI
# ============================================
COMMAND="${1:-help}"
shift || true

rotate_logs

case "$COMMAND" in
    clean)            cmd_clean "$@" ;;
    dashboard)        cmd_dashboard "$@" ;;
    analyze)          cmd_analyze "$@" ;;
    large-files)      cmd_large_files "$@" ;;
    docker)           cmd_docker "$@" ;;
    security)         cmd_security "$@" ;;
    uninstall)        cmd_uninstall ;;
    upgrade)          cmd_upgrade ;;
    network)          cmd_network "$@" ;;
    system-info)      cmd_system_info ;;
    battery)          cmd_battery ;;
    apps)             cmd_apps ;;
    schedule)         cmd_schedule "$@" ;;
    startup)          cmd_startup "$@" ;;
    defaults)         cmd_defaults "$@" ;;
    version|--version|-v)
        echo "CleanMac Pro v$VERSION"
        ;;
    help|--help|-h)
        cat << HELP
CleanMac Pro – macOS optimization suite v$VERSION

Global options:
  --quiet           Suppress non‑essential output
  --json            Output machine‑readable JSON (dry‑run only)
  --log-level LEVEL debug|info|error
  --help, -h        Show this help
  --version, -v     Show version

Commands:
  clean [--dry-run] [--force]  Run system cleaner (--dry-run to preview, --force to bypass confirm)
  dashboard                    Launch interactive TUI
  analyze                      Analyze disk usage (requires ncdu)
  large-files                  Find large files (>100MB)
  docker                       Clean Docker containers/images
  security                     Run security scan
  network <subcommand>         Network tools (status, flush-dns, optimize, reset, monitor, ping)
  system-info                  Display system hardware and OS info
  battery                      Show battery health and cycle count (laptops)
  apps                         List large applications (>1GB)
  schedule <add|remove|status> Manage automated cleaning (cron/launchd)
  startup <list|add|remove>    Manage login items
  defaults <subcommand>        Manage macOS defaults (show/toggle hidden files, show path in Finder)
  upgrade                      Self‑upgrade (git clone only)
  uninstall                    Remove CleanMac Pro completely
  version                      Show version
  help                         Show this help

Examples:
  cleanmac clean --dry-run --json     # JSON preview
  cleanmac clean --quiet              # Silent cleaning
  cleanmac network reset              # Revert TCP tuning
  cleanmac analyze                    # Interactive disk usage
  cleanmac system-info                # Quick system overview
  cleanmac apps                       # Find large apps
  cleanmac schedule add weekly        # Auto‑clean every Sunday
  cleanmac startup list               # Show login items
  cleanmac defaults toggle-hidden-files # Show hidden files in Finder
  cleanmac network ping google.com    # Ping a host

Report issues: https://github.com/Dan13681989/CleanMac-Pro/issues
HELP
        ;;
    *)
        error "Unknown command: $COMMAND\nRun 'cleanmac help' for usage"
        ;;
esac
