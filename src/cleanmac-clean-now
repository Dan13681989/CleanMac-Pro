#!/bin/bash
set -euo pipefail

# Dry-run flag
DRY_RUN=false
if [[ "${1:-}" == "--dry-run" ]]; then
    DRY_RUN=true
    shift
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${GREEN}=== CleanMac Pro Cleaner ===${NC}"
if [[ "$DRY_RUN" == true ]]; then
    echo -e "${YELLOW}DRY RUN MODE – no files will be deleted${NC}"
fi

# Helper function to clean a path safely
clean_item() {
    local path="$1"
    local description="${2:-$path}"
    
    if [[ -e "$path" ]]; then
        if [[ "$DRY_RUN" == true ]]; then
            echo -e "[DRY RUN] Would delete: $description"
        else
            rm -rf "$path" && echo -e "${GREEN}Deleted:${NC} $description"
        fi
    else
        echo -e "[SKIP] $description not found"
    fi
}

# ============================================
# Add your actual cleaning items here.
# Example from typical CleanMac:
# clean_item "$HOME/Library/Caches/com.apple.Safari" "Safari cache"
# clean_item "$HOME/Library/Logs" "System logs"
# clean_item "$HOME/.Trash/*" "Trash"
# ============================================

echo -e "${GREEN}Cleanup finished.${NC}"
